---

---

<footer class="bg-primary bg-opacity-5 relative">
  <div
    class="absolute top-0 left-0 w-full h-px bg-gradient-to-r from-transparent via-primary/20 to-transparent"
  >
  </div>

  <section class="w-5/6 mx-auto">
    <div class="flex gap-y-6 sm:flex-row flex-col-reverse justify-between py-8">
      <!-- Left: name + tagline + CV button -->
      <div class="flex flex-col gap-y-4">
        <h1 class="hero-name font-extrabold text-2xl">Vraj Dobariya</h1>
        <p class="text-gray-400 sm:w-4/6 w-full">
          Crafting innovative solutions and pushing boundaries, one line of code
          at a time.
        </p>
        <a
          href="https://drive.google.com/file/d/1p-9RLnTtGsd88SXLJQqBCGlptPfs_zxn/view"
          target="_blank"
          class="group relative flex items-center gap-2 w-fit px-5 py-2.5 font-bold text-primary text-sm transition-all duration-300 bg-primary/5 border border-primary/20 rounded-xl hover:bg-primary/10 hover:border-primary/40 hover:-translate-y-0.5 hover:shadow-[0_0_20px_rgba(255,255,255,0.07)] overflow-hidden"
        >
          <span
            class="absolute inset-0 w-full h-full -translate-x-full bg-gradient-to-r from-transparent via-white/10 to-transparent group-hover:animate-shimmer"
          ></span>
          <span class="relative z-10">Download Resume</span>
          <svg
            class="relative z-10 fill-current w-4 h-4 transition-transform duration-300 group-hover:translate-y-0.5"
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
          >
            <path
              d="M12 16L7 11l1.4-1.4 2.6 2.6V4h2v8.2l2.6-2.6L17 11l-5 5zm-6 4v-2h12v2H6z"
            ></path>
          </svg>
        </a>
      </div>

      <!-- Right: social links -->
      <div class="flex flex-col gap-y-3">
        <h1 class="text-primary text-xl font-bold">Social Links</h1>
        <div
          class="fill-primary stroke-primary flex sm:justify-end justify-start gap-4 flex-nowrap items-center"
        >
          <a
            aria-label="Github"
            href="https://github.com/vraj-dobariya"
            class="flex flex-row items-center justify-center opacity-60 hover:scale-125 hover:opacity-100 transition-all duration-200"
          >
            <svg
              class="fill-primary h-6 w-6"
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 496 512"
            >
              <path
                d="M165.9 397.4c0 2-2.3 3.6-5.2 3.6-3.3.3-5.6-1.3-5.6-3.6 0-2 2.3-3.6 5.2-3.6 3-.3 5.6 1.3 5.6 3.6zm-31.1-4.5c-.7 2 1.3 4.3 4.3 4.9 2.6 1 5.6 0 6.2-2s-1.3-4.3-4.3-5.2c-2.6-.7-5.5.3-6.2 2.3zm44.2-1.7c-2.9.7-4.9 2.6-4.6 4.9.3 2 2.9 3.3 5.9 2.6 2.9-.7 4.9-2.6 4.6-4.6-.3-1.9-3-3.2-5.9-2.9zM244.8 8C106.1 8 0 113.3 0 252c0 110.9 69.8 205.8 169.5 239.2 12.8 2.3 17.3-5.6 17.3-12.1 0-6.2-.3-40.4-.3-61.4 0 0-70 15-84.7-29.8 0 0-11.4-29.1-27.8-36.6 0 0-22.9-15.7 1.6-15.4 0 0 24.9 2 38.6 25.8 21.9 38.6 58.6 27.5 72.9 20.9 2.3-16 8.8-27.1 16-33.7-55.9-6.2-112.3-14.3-112.3-110.5 0-27.5 7.6-41.3 23.6-58.9-2.6-6.5-11.1-33.3 2.6-67.9 20.9-6.5 69 27 69 27 20-5.6 41.5-8.5 62.8-8.5s42.8 2.9 62.8 8.5c0 0 48.1-33.6 69-27 13.7 34.7 5.2 61.4 2.6 67.9 16 17.7 25.8 31.5 25.8 58.9 0 96.5-58.9 104.2-114.8 110.5 9.2 7.9 17 22.9 17 46.4 0 33.7-.3 75.4-.3 83.6 0 6.5 4.6 14.4 17.3 12.1C428.2 457.8 496 362.9 496 252 496 113.3 383.5 8 244.8 8zM97.2 352.9c-1.3 1-1 3.3.7 5.2 1.6 1.6 3.9 2.3 5.2 1 1.3-1 1-3.3-.7-5.2-1.6-1.6-3.9-2.3-5.2-1zm-10.8-8.1c-.7 1.3.3 2.9 2.3 3.9 1.6 1 3.6.7 4.3-.7.7-1.3-.3-2.9-2.3-3.9-2-.6-3.6-.3-4.3.7zm32.4 35.6c-1.6 1.3-1 4.3 1.3 6.2 2.3 2.3 5.2 2.6 6.5 1 1.3-1.3.7-4.3-1.3-6.2-2.2-2.3-5.2-2.6-6.5-1zm-11.4-14.7c-1.6 1-1.6 3.6 0 5.9 1.6 2.3 4.3 3.3 5.6 2.3 1.6-1.3 1.6-3.9 0-6.2-1.4-2.3-4-3.3-5.6-2z"
              ></path>
            </svg>
          </a>
          <a
            href="https://www.linkedin.com/in/vraj-dobariya-3713b8289/"
            aria-label="Linkedin"
            class="flex items-center justify-center opacity-60 hover:scale-125 hover:opacity-100 transition-all duration-200"
          >
            <svg
              class="fill-primary h-6 w-6"
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 448 512"
            >
              <path
                d="M416 32H31.9C14.3 32 0 46.5 0 64.3v383.4C0 465.5 14.3 480 31.9 480H416c17.6 0 32-14.5 32-32.3V64.3c0-17.8-14.4-32.3-32-32.3zM135.4 416H69V202.2h66.5V416zm-33.2-243c-21.3 0-38.5-17.3-38.5-38.5S80.9 96 102.2 96c21.2 0 38.5 17.3 38.5 38.5 0 21.3-17.2 38.5-38.5 38.5zm282.1 243h-66.4V312c0-24.8-.5-56.7-34.5-56.7-34.6 0-39.9 27-39.9 54.9V416h-66.4V202.2h63.7v29.2h.9c8.9-16.8 30.6-34.5 62.9-34.5 67.2 0 79.7 44.3 79.7 101.9V416z"
