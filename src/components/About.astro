---

---

<section id="about" class="w-5/6 mx-auto m-6">
  <div class="gap-8 py-8 px-4 mx-auto">
    <div class="mt-4 md:mt-0">
      <h2
        data-aos="fade-up"
        data-aos-anchor-placement="center-bottom"
        class="mb-6 text-4xl tracking-tight font-extrabold text-primary text-transparent bg-clip-text bg-gradient-to-r from-[#d7d7d7] to-[#616161] sm:text-3xl md:text-5xl pb-2 text-center"
      >
        About me!
      </h2>

      <p
        data-aos="fade-up"
        data-aos-anchor-placement="center-bottom"
        class="mb-6 font-light text-gray-300 sm:text-sm md:text-xl text-left dark:text-gray-300 sm:w-5/6 w-full mx-auto"
      >
        I am currently working as a <b class="font-bold"
          >Software Dev Engineer Intern at Sameeksha Capital</b
        >, where I focus on building systems for research automation and fund
        management. Previously, I worked as a <b class="font-bold"
          >Software Engineer Intern at Google (2025)</b
        >, where I developed Google Cloud SecOps Data Export Enhanced APIs. I am
        also a final-year B.Tech student in ICT at <b class="font-bold"
          >Dhirubhai Ambani University</b
        >.
        <br />
        <br />
        I enjoy building <b class="font-bold">scalable and reliable systems</b> and
        solving complex engineering problems end-to-end. My core expertise lies in
        <b class="font-bold">Backend Development</b> with hands-on experience in
        <b class="font-bold">Golang and Python</b>, along with technologies such
        as
        <b class="font-bold"
          >Google Spanner, Protocol Buffers, PostgreSQL and Django</b
        >. I value clean design, thoughtful trade-offs, a good ownership and
        writing maintainable code that scales with real-world usage.
      </p>
    </div>
  </div>
  <section class="py-10">
    <div class="container mx-auto">
      <div>
        <h1
          data-aos="fade-up"
          data-aos-anchor-placement="center-bottom"
          class="mb-4 text-2xl text-transparent bg-clip-text bg-gradient-to-r from-[#d7d7d7] to-[#616161] font-extrabold py-3 text-center"
        >
          Professional Skillset
        </h1>
        <div
          class="skills-grid flex gap-6 flex-wrap w-full sm:justify-center justify-center"
        >
          <!-- JavaScript -->
          <div
            class="w-14 h-14 flex items-center justify-center skill-icon"
            data-aos="zoom-in"
            data-aos-delay="0"
            title="JavaScript"
          >
            <img
              src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/javascript/javascript-original.svg"
              alt="JavaScript"
              class="h-12 w-auto"
            />
          </div>

          <!-- React JS -->
          <div
            class="w-14 h-14 flex items-center justify-center skill-icon"
            data-aos="zoom-in"
            data-aos-delay="100"
            title="React JS"
          >
            <img
              src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/react/react-original.svg"
              alt="React JS"
              class="h-12 w-auto"
            />
          </div>

          <!-- Node JS -->
          <div
            class="w-14 h-14 flex items-center justify-center skill-icon"
            data-aos="zoom-in"
            data-aos-delay="200"
            title="Node JS"
          >
            <img
              src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/nodejs/nodejs-original-wordmark.svg"
              alt="Node JS"
              class="h-12 w-auto"
            />
          </div>

          <!-- GoLang -->
          <div
            class="w-14 h-14 flex items-center justify-center skill-icon"
            data-aos="zoom-in"
            data-aos-delay="300"
            title="GoLang"
          >
            <img
              src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/go/go-original.svg"
              alt="GoLang"
              class="h-12 w-auto"
            />
          </div>

          <!-- Python -->
          <div
            class="w-14 h-14 flex items-center justify-center skill-icon"
            data-aos="zoom-in"
            data-aos-delay="400"
            title="Python"
          >
            <img
              src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/python/python-original.svg"
              alt="Python"
              class="h-12 w-auto"
            />
          </div>

          <!-- C++ -->
          <div
            class="w-14 h-14 flex items-center justify-center skill-icon"
            data-aos="zoom-in"
            data-aos-delay="600"
            title="C++"
          >
            <img
              src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/cplusplus/cplusplus-original.svg"
              alt="C++"
              class="h-12 w-auto"
            />
          </div>
        </div>
      </div>

      <div class="mt-8">
        <h1
          data-aos="fade-up"
          data-aos-anchor-placement="center-bottom"
          class="mb-4 text-2xl text-transparent bg-clip-text bg-gradient-to-r from-[#d7d7d7] to-[#616161] font-extrabold py-3 text-center"
        >
          Tools
        </h1>
        <div
          class="skills-grid flex gap-6 flex-wrap w-full sm:justify-center justify-center"
        >
          <!-- Git -->
          <div
            class="w-14 h-14 flex items-center justify-center skill-icon"
            data-aos="zoom-in"
            data-aos-delay="0"
            title="Git"
          >
            <img
              src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/git/git-original.svg"
              alt="Git"
              class="h-12 w-auto"
            />
          </div>

          <!-- VS Code -->
          <div
            class="w-14 h-14 flex items-center justify-center skill-icon"
            data-aos="zoom-in"
            data-aos-delay="100"
            title="VS Code"
          >
            <img
              src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/vscode/vscode-original.svg"
              alt="VS Code"
              class="h-12 w-auto"
            />
          </div>

          <!-- Postman -->
          <div
            class="w-14 h-14 flex items-center justify-center skill-icon"
            data-aos="zoom-in"
            data-aos-delay="200"
            title="Postman"
          >
            <img
              src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/postman/postman-original.svg"
              alt="Postman"
              class="h-12 w-auto"
            />
          </div>

          <!-- Bitbucket -->
          <div
            class="w-14 h-14 flex items-center justify-center skill-icon"
            data-aos="zoom-in"
            data-aos-delay="300"
            title="Bitbucket"
          >
            <img
              src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/bitbucket/bitbucket-original.svg"
              alt="Bitbucket"
              class="h-12 w-auto"
            />
          </div>

          <!-- Google Cloud -->
          <div
            class="w-14 h-14 flex items-center justify-center skill-icon"
            data-aos="zoom-in"
            data-aos-delay="400"
            title="Google Cloud"
          >
            <img
              src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/googlecloud/googlecloud-original.svg"
              alt="Google Cloud"
              class="fill-primary h-12 w-auto"
            />
          </div>

          <!-- Google Cloud Spanner -->
          <div
            class="w-14 h-14 flex items-center justify-center skill-icon"
            data-aos="zoom-in"
            data-aos-delay="400"
            title="Google Cloud Spanner"
          >
            <svg
              class="h-12 w-auto fill-current text-gray-400"
              viewBox="0 0 32 32"
              xmlns="http://www.w3.org/2000/svg"
            >
              <path
                d="M12 9.06 7.944 6.864V2.388L10.38.924v3.66l1.62.744 1.62-.744V.924l2.436 1.464v4.476L12 9.06zm-8.124 4.752L0 16.056v2.988l3.228-1.86 1.404.912.096 1.632-3.24 1.872 2.616 1.476 3.828-2.268-.132-4.596-3.924-2.4zm9.732-.9V8.758l-1.37.742-.238.129-.238-.13-1.37-.741v4.154l-3.613 2.09 1.282.783.231.142.008.27.046 1.612L12 15.696l3.595 2.079.045-1.59.008-.27.231-.142 1.301-.795-3.572-2.066zm7.164 4.272L24 19.044v-2.988L20.064 13.8l-3.924 2.4-.132 4.596 3.888 2.244 2.616-1.44-3.24-1.836.096-1.668 1.404-.912z"
              ></path>
            </svg>
          </div>

          <!-- Docker -->
          <!-- <div
            class="w-14 h-14 flex items-center justify-center skill-icon"
            data-aos="zoom-in"
            data-aos-delay="300"
            title="Docker"
          >
            <img
              src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/docker/docker-original.svg"
              alt="Docker"
              class="h-12 w-auto"
            />
          </div> -->
        </div>
      </div>
    </div>
  </section>
</section>

<style>
  /* Target both img and svg within the skill-icon */
  .skill-icon img,
  .skill-icon svg {
    opacity: 0.85;
    transition:
      opacity 0.3s ease,
      transform 0.3s ease,
      filter 0.3s ease,
      fill 0.3s ease; /* Added fill transition for SVGs */
  }

  /* Apply hover effects to both */
  .skill-icon:hover img,
  .skill-icon:hover svg {
    opacity: 1;
    transform: scale(1.22) translateY(-4px);
    filter: drop-shadow(0 4px 12px rgba(255, 255, 255, 0.18));
  }

  /* Optional: Change SVG color on hover if you want it to "light up" */
  .skill-icon:hover svg {
    fill: #2172f5; /* Google Blue, or any highlight color */
  }
</style>
