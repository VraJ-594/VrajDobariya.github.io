<style>
  /* Individual skill icon hover — de-grayscale + lift */
  .skills-grid > div {
    cursor: default;
  }

  .skills-grid > div > svg {
    filter: grayscale(1);
    opacity: 0.75;
    transition:
      filter 0.3s ease,
      opacity 0.3s ease,
      transform 0.3s ease;
  }

  .skills-grid > div:hover > svg {
    filter: grayscale(0);
    opacity: 1;
    transform: scale(1.18) translateY(-3px);
  }
</style>
