---

---

<section id="achievements" class="max-md:w-full w-5/6 mx-auto">
  <div class="py-48 flex flex-col items-center">
    <h1
      data-aos="fade-up"
      data-aos-anchor-placement="center-bottom"
      class="mb-8 font-extrabold text-center text-4xl text-transparent bg-clip-text bg-gradient-to-tr from-[#d7d7d7] to-[#616161] sm:text-3xl md:text-5xl"
    >
      Achievements
    </h1>

    <!-- Competitive Programming Ratings -->
    <div
      data-aos="fade-up"
      data-aos-anchor-placement="center-bottom"
      class="mt-8 max-md:w-5/6 w-3/4"
    >
      <h2 class="text-center text-gray-400 font-semibold text-lg mb-6">
        Competitive Programming
      </h2>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
        <!-- Codeforces -->
        <a
          href="https://codeforces.com/profile/Vraj_Dobariya_95"
          target="_blank"
          rel="noopener noreferrer"
          class="achieve-card group flex flex-col items-center gap-2 border border-primary/10 bg-primary/5 rounded-xl py-5 px-3 text-center hover:border-indigo-400/40"
        >
          <span class="text-2xl h-8 w-8 object-contain"
            ><img
              src="data:image/png;base64,"
              alt="external-codeforces-programming-competitions-and-contests-programming-community-logo-filled-tal-revivo"
            /></span
          >
          <p class="text-primary font-bold text-sm">Codeforces</p>
          <p class="text-indigo-300 font-semibold text-xs">Expert</p>
          <p class="text-gray-400 text-xs">Max: 1755</p>
        </a>

        <!-- CodeChef -->
        <a
          href="https://www.codechef.com/users/dobariyavraj66"
          target="_blank"
          rel="noopener noreferrer"
          class="achieve-card group flex flex-col items-center gap-2 border border-primary/10 bg-primary/5 rounded-xl py-5 px-3 text-center hover:border-indigo-400/40"
        >
          <span class="text-2xl h-8 w-8 object-contain"
            ><img
              src="data:image/png;base64,"
              alt="codechef"
            /></span
          >
          <p class="text-primary font-bold text-sm">CodeChef</p>
          <p class="text-indigo-300 font-semibold text-xs">5-Star</p>
          <p class="text-gray-400 text-xs">Max: 2040</p>
        </a>

        <!-- LeetCode -->
        <a
          href="https://leetcode.com/u/Vraj_Dobariya_59/"
          target="_blank"
          rel="noopener noreferrer"
          class="achieve-card group flex flex-col items-center gap-2 border border-primary/10 bg-primary/5 rounded-xl py-5 px-3 text-center hover:border-indigo-400/40"
        >
          <span class="text-2xl h-8 w-8 object-contain"
            ><img
              src="data:image/png;base64,"
              alt="external-level-up-your-coding-skills-and-quickly-land-a-job-logo-shadow-tal-revivo"
            /></span
          >
          <p class="text-primary font-bold text-sm">LeetCode</p>
          <p class="text-indigo-300 font-semibold text-xs">Guardian</p>
          <p class="text-gray-400 text-xs">Max: 2164</p>
        </a>

        <!-- AtCoder -->
        <a
          href="https://atcoder.jp/users/Vraj_Dobariya_59"
          target="_blank"
          rel="noopener noreferrer"
          class="achieve-card group flex flex-col items-center gap-2 border border-primary/10 bg-primary/5 rounded-xl py-5 px-3 text-center hover:border-indigo-400/40"
        >
          <span class="text-2xl h-8 w-8 object-contain"
            ><img
              src="https://cdn.brandfetch.io/idZMTV6iO2/w/280/h/280/theme/dark/logo.png?c=1bxid64Mup7aczewSAYMX&t=1767340377001"
            /></span
          >
          <p class="text-primary font-bold text-sm">AtCoder</p>
          <p class="text-indigo-300 font-semibold text-xs">4 Kyu</p>
          <p class="text-gray-400 text-xs">Max: 1234</p>
        </a>
      </div>
    </div>

    <!-- Other Achievements -->
    <div
      data-aos="fade-up"
      data-aos-anchor-placement="center-bottom"
      data-aos-delay="100"
      class="mt-10 max-md:w-5/6 w-3/4 flex flex-col gap-4"
    >
      <h2 class="text-center text-gray-400 font-semibold text-lg mb-2">
        Highlights
      </h2>

      <div
        class="achieve-row border border-primary/10 bg-primary/5 rounded-xl px-6 py-4 flex items-center gap-4"
      >
        <span class="text-xl shrink-0">🥈</span>
        <p class="text-primary font-medium max-md:text-sm">
          <span class="text-indigo-300 font-semibold">Runners Up</span> at
          <span class="text-indigo-300 font-semibold">Faceoff 2025</span>
          (MSTC – DAIICT)
        </p>
      </div>

      <div
        class="achieve-row border border-primary/10 bg-primary/5 rounded-xl px-6 py-4 flex items-center gap-4"
      >
        <span class="text-xl shrink-0 size=2"
          ><img
            src="data:image/png;base64,"
            alt="meta"
            class="h-6 w-6 object-contain"
          /></span
        >
        <p class="text-primary font-medium max-md:text-sm">
          <span class="text-indigo-300 font-semibold">Meta Hacker Cup 2025</span
          >
          — Round 2, Rank <span class="text-indigo-300 font-semibold">678</span>
        </p>
      </div>

      <div
        class="achieve-row border border-primary/10 bg-primary/5 rounded-xl px-6 py-4 flex items-center gap-4"
      >
        <span class="text-xl shrink-0">💡</span>
        <p class="text-primary font-medium max-md:text-sm">
          Solved <span class="text-indigo-300 font-semibold"
            >1000+ competitive programming</span
          > problems
        </p>
      </div>

      <div
        class="achieve-row border border-primary/10 bg-primary/5 rounded-xl px-6 py-4 flex items-center gap-4"
      >
        <span class="text-xl shrink-0">🥇</span>
        <p class="text-primary font-medium max-md:text-sm">
          <span class="text-indigo-300 font-semibold"
            >Coding World Cup 2023</span
          >
          at CodingNinjas — 1st place for two consecutive weeks
        </p>
      </div>

      <div
        class="achieve-row border border-primary/10 bg-primary/5 rounded-xl px-6 py-4 flex items-center gap-4"
      >
        <span class="text-xl shrink-0">📝</span>
        <p class="text-primary font-medium max-md:text-sm">
          <span class="text-indigo-300 font-semibold">JEE Mains 2022</span>
          — 99.36 percentile · AIR <span class="text-indigo-300 font-semibold"
            >5917</span
          >
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  .achieve-card {
    transition:
      transform 0.25s ease,
      box-shadow 0.25s ease,
      background-color 0.25s ease;
  }
  .achieve-card:hover {
    transform: translateY(-4px) scale(1.03);
    box-shadow: 0 8px 28px rgba(0, 0, 0, 0.4);
    background-color: rgba(255, 255, 255, 0.06);
  }

  .achieve-row {
    transition:
      transform 0.2s ease,
      background-color 0.2s ease;
  }
  .achieve-row:hover {
    transform: translateX(4px);
    background-color: rgba(255, 255, 255, 0.05);
  }
</style>
