---

---

<div data-aos="fade-up" class="mx-auto py-4 lg:py-4">
  <div class="w-96 text-center mx-auto flex justify-center">
    <div
      class="w-60 h-60 flex items-center justify-center rounded-full p-2 bg-gradient-to-tr from-slate-400/30 to-transparent shadow-2xl transition-transform duration-300 hover:scale-105 hover:shadow-primary/30 cursor-pointer"
    >
      <img
        src="/VrajDobariya.github.io/profile.png"
        alt="Vraj Dobariya"
        class="w-full h-full object-cover rounded-full ring-4 ring-white dark:ring-slate-900 shadow-inner"
      />
    </div>
  </div>
  <div class="text-center">
    <p
      data-aos="fade-up"
      data-aos-delay="100"
      class="hero-name text-3xl pt-4 font-bold text-primary sm:text-3xl md:text-5xl pb-2"
    >
      Hi, I&apos;m Vraj Dobariya
    </p>
    <p
      data-aos="fade-up"
      data-aos-delay="250"
      class="text-base mt-4 font-bold text-transparent bg-clip-text bg-gradient-to-r from-[#d7d7d7] to-[#616161] sm:text-xl md:text-3xl pb-2"
    >
      a student who enjoys building reliable systems and solving problems!<span
        class="typing-cursor">|</span
      >
    </p>
    <a
      data-aos="fade-up"
      data-aos-delay="400"
      href="#about"
      class="cursor-pointer w-full h-full z-50"
    >
      <svg
        viewBox="0 0 24 24"
        class="animate-bounce stroke-primary h-8 flex justify-center w-full mt-3 sm:mt-6 sm:h-10"
        height="1em"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
        ><g id="SVGRepo_bgCarrier" stroke-width="0"></g><g
          id="SVGRepo_tracerCarrier"
          stroke-linecap="round"
          stroke-linejoin="round"></g><g id="SVGRepo_iconCarrier">
          <path
            d="M19 9L14 14.1599C13.7429 14.4323 13.4329 14.6493 13.089 14.7976C12.7451 14.9459 12.3745 15.0225 12 15.0225C11.6255 15.0225 11.2549 14.9459 10.9109 14.7976C10.567 14.6493 10.2571 14.4323 10 14.1599L5 9"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
        </g></svg
      >
    </a>
  </div>
</div>

<style is:inline>
  :root {
    --color: rgba(71, 71, 71, 0.918);
  }

  /* Shimmer sweep across the name gradient */
  .hero-name {
    background: linear-gradient(
      110deg,
      #616161 0%,
      #d7d7d7 30%,
      #ffffff 50%,
      #d7d7d7 70%,
      #616161 100%
    );
    background-size: 250% auto;
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    animation: shimmer 4s linear infinite;
  }

  @keyframes shimmer {
    0% {
      background-position: 200% center;
    }
    100% {
      background-position: -200% center;
    }
  }

  /* Blinking cursor after subtitle */
  .typing-cursor {
    display: inline-block;
    margin-left: 2px;
    color: #9ca3af;
    animation: blink 1.1s step-start infinite;
    -webkit-text-fill-color: #9ca3af;
  }

  @keyframes blink {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0;
    }
  }
</style>
